# Rust build artifacts
/target/
/kernel/target/
/userspace/target/
# `hal` and `qemu-test-runner` are each their own workspace root (see the
# root Cargo.toml's `exclude`), so each grows its own target/ dir rather
# than sharing the root one above.
/hal/target/
/qemu-test-runner/target/

# Claude Code local state. `.claude/skills/` IS tracked (project tooling,
# referenced by docs/drivers/), but these two are per-machine and personal.
/.claude/settings.local.json
/.claude/scheduled_tasks.lock

# mlibc build artifacts (regenerated by scripts/setup-mlibc.sh)
/build-mlibc/
/sysroot/

# busybox build artifacts (regenerated by scripts/build-busybox.sh)
/build-busybox/

# doomgeneric build artifacts (regenerated by scripts/build-doom.sh)
/build-doom/

# quakegeneric build artifacts (regenerated by scripts/build-quake.sh)
/build-quake/

# Freedoom IWAD (~29MB, fetched by scripts/fetch-freedoom.sh) — a large
# external data asset, not source; kept out of git like sysroot/ rather
# than committed like the smaller embedded *.elf program binaries. Landed
# in disk-image-root/ by the fetch script, from where the workspace-root
# build.rs seeds it into disk.img (ext2, mounted read-only at /mnt) —
# that's where DOOM reads it from at runtime, not a kernel-embedded copy.
/disk-image-root/freedoom1.wad
/disk-image-root/freedoom-COPYING.txt

# Quake shareware pak0.pak (~18MB, fetched by
# scripts/fetch-quake-shareware.sh) — same rationale as freedoom1.wad above.
/disk-image-root/id1/

# Userspace ELFs built straight here by kernel/build.rs (doom, quake, and
# most of the old C test programs — see that file's module doc comment) —
# a build artifact, rebuilt every `cargo build`, not source. Synced onto
# disk.img's /bin by the root build.rs's sync_disk_bin_dir.
/disk-image-root/bin/

# Bootloader artifacts
bootimage-*.bin
*.img

# QEMU disk images
*.qcow2

# Debug files
*.pdb

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
Thumbs.db

# Logs
*.log

# UEFI artifacts
OVMF*.fd
*.efi

# Temporary files
*.tmp

# Test artifacts
test-*.log